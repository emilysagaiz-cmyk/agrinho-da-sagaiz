<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agrotec Sustentável - Comedouro</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- Header / Hero -->
    <header class="hero">
        <div class="overlay">
            <h1>Comedouro Sustentável</h1>
            <p>Eficiência, economia e bem-estar animal</p>
            <a href="#contato" class="btn">Solicitar Orçamento</a>
        </div>
    </header>

    <!-- Seção Comedouro -->
    <section id="comedouro" class="produto">
        <div class="container">
            <div class="imagem">
                <img src="https://images.unsplash.com/photo-1500595046743-cd271d694d30?w=1200" alt="Comedouro Sustentável">
            </div>
            <div class="conteudo">
                <h2>Comedouro Inteligente</h2>
                <p>Reduz desperdícios de ração, facilita o manejo e aumenta a produtividade.</p>
                <ul>
                    <li>✔ Estrutura resistente</li>
                    <li>✔ Fácil limpeza</li>
                    <li>✔ Menor desperdício</li>
                    <li>✔ Alta durabilidade</li>
                </ul>
                <button id="saibaMais">Saiba Mais</button>
            </div>
        </div>
    </section>

    <!-- Benefícios -->
    <section class="beneficios">
        <h2>Benefícios</h2>
        <div class="cards">
            <div class="card">
                <h3>Economia</h3>
                <p>Redução significativa das perdas de ração.</p>
            </div>
            <div class="card">
                <h3>Praticidade</h3>
                <p>Instalação simples e manutenção rápida.</p>
            </div>
            <div class="card">
                <h3>Sustentabilidade</h3>
                <p>Melhor aproveitamento dos recursos da propriedade.</p>
            </div>
        </div>
    </section>

    <!-- Galeria -->
    <section class="galeria">
        <h2>Galeria</h2>
        <div class="grid">
            <img src="https://images.unsplash.com/photo-1516467508483-a7212febe31a?w=800" alt="Imagem 1">
            <img src="https://images.unsplash.com/photo-1517849845537-4d257902454a?w=800" alt="Imagem 2">
            <img src="https://images.unsplash.com/photo-1500595046743-cd271d694d30?w=800" alt="Imagem 3">
        </div>
    </section>

    <!-- Contato -->
    <section id="contato" class="contato">
        <h2>Entre em Contato</h2>
        <form>
            <input type="text" placeholder="Nome" required>
            <input type="email" placeholder="E-mail" required>
            <textarea placeholder="Mensagem" required></textarea>
            <button type="submit">Enviar</button>
        </form>
    </section>

    <!-- Footer -->
    <footer>
        <p>© 2026 Agrotec Sustentável</p>
    </footer>

    <script src="script.js"></script>
</body>
</html>
